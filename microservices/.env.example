# Modele de configuration -- COPIER en .env et remplir.
# Le vrai .env est ignore par Git (.gitignore) : n'y mets jamais de valeur reelle ici.

# ── Scrapers ──────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
GEMINI_API_KEY=

# ── Kernel organization-core (ingestion des agences -> ES) ────────────────
# URL de la passerelle Kernel. Reseau PRIVE : joignable seulement via VPN/labo.
KERNEL_API_URL=http://api.10.50.30.102.nip.io
# Identite machine : ClientApplication a faire provisionner par l'equipe Kernel
# (avec ORGANIZATION dans allowedServiceCodes). Le secret n'est montre qu'une fois.
KERNEL_CLIENT_ID=
KERNEL_API_KEY=
KERNEL_TENANT_ID=
# CSV des organizationId a indexer (ex: org-a,org-b). Vide => sync desactive.
KERNEL_ORGANIZATION_IDS=
