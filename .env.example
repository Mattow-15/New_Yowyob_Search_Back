# yowyob-search — .env de PRODUCTION (serveur yowyob). Copier en .env, NE PAS committer.

# Image fournie par le pipeline (le job deploy passe SEARCH_IMAGE).
SEARCH_IMAGE=ghcr.io/yowyob/yowyob-search:latest

# Auth déléguée au kernel : aucune clé statique. yowyob-search valide X-Client-Id + X-Api-Key
# (d'un clientApplication du kernel) via GET /api/client-applications/me. Régler l'URL interne du
# kernel sur le réseau Docker yowyob (laisser le défaut si le conteneur s'appelle ainsi).
KERNEL_BASE_URL=http://kernel-core-kernel-layer-1:8080
